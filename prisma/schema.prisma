generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Products from Line List
model Product {
  id                      String   @id @default(cuid())
  styleNumber             String
  styleDesc               String?
  color                   String?
  colorDesc               String?
  styleColor              String?
  season                  String
  seasonType              String?
  divisionDesc            String?
  categoryDesc            String?
  category                String?
  productLine             String?
  productLineDesc         String?
  labelDesc               String?
  designerName            String?
  techDesignerName        String?
  countryOfOrigin         String?
  factoryName             String?
  msrp                    Float    @default(0)
  price                   Float    @default(0)
  cost                    Float    @default(0)
  cadMsrp                 Float?
  cadPrice                Float?
  carryOver               Boolean  @default(false)
  carryForward            Boolean  @default(false)
  sellingSeasons          String?
  htsCode                 String?
  styleColorNotes         String?
  workbook                String?   // Catalog assignment: "WHOLESALE", "WEB", "REI", "REI / WEB", etc.
  market                  String?   // Market channel: "WHOLESALE", "DIRECT", "WHSL/DIRECT"
  catalogOrder            Int?      // Sort order within catalog
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([styleNumber, color, season])
  @@index([season])
  @@index([styleNumber])
  @@index([divisionDesc])
  @@index([categoryDesc])
}

// Sales data
model Sale {
  id                    String    @id @default(cuid())
  styleNumber           String
  styleDesc             String?
  colorCode             String?
  colorDesc             String?
  season                String
  seasonType            String?
  customer              String?
  customerType          String?
  salesRep              String?
  divisionDesc          String?
  categoryDesc          String?
  gender                String?
  unitsBooked           Int       @default(0)
  unitsOpen             Int       @default(0)
  revenue               Float     @default(0)
  shipped               Float     @default(0)
  cost                  Float     @default(0)
  wholesalePrice        Float     @default(0)
  msrp                  Float     @default(0)
  netUnitPrice          Float     @default(0)
  orderType             String?
  // New fields from detailed sales report
  invoiceDate           DateTime?
  accountingPeriod      String?
  invoiceNumber         String?
  shipToState           String?
  returnedAtNet         Float     @default(0)
  shippedAtNet          Float     @default(0)
  totalPrice            Float     @default(0)
  commissionRate        Float     @default(0)
  ytdNetInvoicing       Float     @default(0)
  ytdCreditMemos        Float     @default(0)
  ytdSales              Float     @default(0)
  warehouse             String?
  warehouseDesc         String?
  openAtNet             Float     @default(0)
  openOrder             Float     @default(0)
  returned              Float     @default(0)
  shippedAtMsrp         Float     @default(0)
  totalAtNet            Float     @default(0)
  totalAtWholesale      Float     @default(0)
  returnedAtWholesale   Float     @default(0)
  // Geographic fields
  shipToCity            String?
  shipToZip             String?
  billToState           String?
  billToCity            String?
  billToZip             String?
  // Unit counts
  unitsShipped          Int       @default(0)
  unitsReturned         Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([season])
  @@index([styleNumber])
  @@index([customer])
  @@index([customerType])
  @@index([invoiceDate])
  @@index([accountingPeriod])
  @@index([shipToState])
}

// Invoice data — separate from sales, contains geographic fields for heat map
model Invoice {
  id                    String    @id @default(cuid())
  styleNumber           String
  styleDesc             String?
  colorCode             String?
  colorDesc             String?
  season                String
  customer              String?
  customerType          String?
  gender                String?
  orderType             String?
  // Geographic fields
  shipToState           String?
  shipToCity            String?
  shipToZip             String?
  billToState           String?
  billToCity            String?
  billToZip             String?
  // Invoice fields
  invoiceNumber         String?
  invoiceDate           DateTime?
  accountingPeriod      String?
  shippedAtNet          Float     @default(0)
  returnedAtNet         Float     @default(0)
  totalPrice            Float     @default(0)
  totalAtNet            Float     @default(0)
  totalAtWholesale      Float     @default(0)
  returnedAtWholesale   Float     @default(0)
  shippedAtMsrp         Float     @default(0)
  warehouse             String?
  warehouseDesc         String?
  commissionRate        Float     @default(0)
  ytdNetInvoicing       Float     @default(0)
  ytdCreditMemos        Float     @default(0)
  ytdSales              Float     @default(0)
  openAtNet             Float     @default(0)
  openOrder             Float     @default(0)
  returned              Float     @default(0)
  unitsShipped          Int       @default(0)
  unitsReturned         Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([season])
  @@index([styleNumber])
  @@index([shipToState])
  @@index([invoiceDate])
  @@index([customer])
  // Composite unique key — prevents duplicate rows when re-importing the
  // same invoice file. Combined with skipDuplicates on createMany, lets
  // imports be idempotent without delete-then-insert.
  //
  // Wider than the obvious (invoiceNumber, styleNumber, colorCode, customer)
  // because real distinct line items often share those four fields — same
  // invoice can have separate lines per warehouse, ship-to location, or
  // size pricing tier. The xlsx export carries no line-item-id, so we have
  // to reconstruct uniqueness from the discriminating columns it does
  // provide. Truly identical rows across all of these are real duplicates
  // and get skipped; anything else lands.
  //
  // The DB index is created with NULLS NOT DISTINCT (Postgres 15+) — see
  // src/app/api/admin/add-invoice-unique-key/route.ts. Prisma's @@unique
  // can't express that, but it's required: many invoice rows have NULL
  // warehouse, and Postgres's default NULLS DISTINCT lets identical
  // rows-with-NULLs slip through skipDuplicates and double-count.
  @@unique([invoiceNumber, styleNumber, colorCode, customer, shippedAtNet, returnedAtNet, warehouse, shipToCity, shipToState], name: "invoice_natural_key")
}

// Pricing by season (from pricebyseason file)
model Pricing {
  id          String   @id @default(cuid())
  styleNumber String
  styleDesc   String?
  colorCode   String?
  colorDesc   String?
  season      String
  seasonType  String?
  seasonDesc  String?
  price       Float    @default(0)
  msrp        Float    @default(0)
  cost        Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([styleNumber, colorCode, season])
  @@index([season])
  @@index([styleNumber])
}

// Cost data from Landed Request Sheet or Standard Cost Sheet
model Cost {
  id                  String   @id @default(cuid())
  styleNumber         String
  styleName           String?
  season              String
  seasonType          String?
  factory             String?
  countryOfOrigin     String?
  designTeam          String?
  developer           String?
  fob                 Float    @default(0)
  landed              Float    @default(0)
  dutyCost            Float    @default(0)
  tariffCost          Float    @default(0)
  freightCost         Float    @default(0)
  overheadCost        Float    @default(0)
  suggestedMsrp       Float?
  suggestedWholesale  Float?
  margin              Float?
  costSource          String?  // 'landed_cost' (priority 1) or 'standard_cost' (priority 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([styleNumber, season])
  @@index([season])
  @@index([styleNumber])
}

// kuhl.com site status per style — populated by the sync endpoint when
// credentials are configured (STRAPI_API_TOKEN or KUHL_API_KEY env vars).
// Inert and stays empty until config is provided.
model KuhlSiteStatus {
  id             String   @id @default(cuid())
  styleNumber    String   @unique
  isLive         Boolean?
  siteUrl        String?
  currentPrice   Float?
  currentMsrp    Float?
  source         String?  // "strapi" | "api" | "error"
  errorMessage   String?
  lastCheckedAt  DateTime @default(now())

  @@index([isLive])
}

// ATS (Available To Sell) inventory snapshot, aggregated to style × color.
// Imported via xlsx. Each import replaces all rows for a new snapshot.
model AtsInventory {
  id                     String   @id @default(cuid())
  styleNumber            String
  color                  String
  styleDesc              String?
  colorDesc              String?
  gender                 String?
  category               String?
  styleSegment           String?
  blockCode              String?
  classification         String?  // ALL, WEB, SMU, RUN, ATS, DON, CLOS, 30, 50, 70, etc.
  wholesale              Float    @default(0)
  msrp                   Float    @default(0)
  styleVendor            String?
  warehouse              String?
  unitsATS               Float    @default(0)
  unitsOnHand            Float    @default(0)
  unitsAtOnce            Float    @default(0)
  snapshotDate           DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([styleNumber, color])
  @@index([classification])
  @@index([styleNumber])
}

// Decision audit — who decided what action to take on a style × color
// after reviewing it in the Pullback view. Free-text decidedBy since
// there's no auth system (same pattern as CostEdit / PricingEdit).
model AtsDecision {
  id           String   @id @default(cuid())
  styleNumber  String
  color        String
  action       String   // PULL_FROM_SITE, CANCEL_ORDERS, LIQUIDATE, KEEP, OTHER
  decidedBy    String
  note         String?
  decidedAt    DateTime @default(now())

  @@index([styleNumber, color])
  @@index([decidedAt])
}

// Audit log for inline pricing edits (price, msrp) made through the UI.
// Same pattern as CostEdit — free-text editedBy since there's no auth.
model PricingEdit {
  id          String   @id @default(cuid())
  pricingId   String
  styleNumber String
  season      String
  field       String   // "price" or "msrp"
  oldValue    Float?
  newValue    Float?
  editedBy    String
  note        String?
  editedAt    DateTime @default(now())

  @@index([pricingId])
  @@index([styleNumber, season])
  @@index([editedAt])
}

// Audit log for inline cost edits (landed, margin) made through the UI.
// There is no auth system, so `editedBy` is a free-text name the user types,
// matching the existing ImportLog.importedBy pattern.
model CostEdit {
  id          String   @id @default(cuid())
  costId      String
  styleNumber String
  season      String
  field       String   // "landed" or "margin"
  oldValue    Float?
  newValue    Float?
  editedBy    String
  note        String?
  editedAt    DateTime @default(now())

  @@index([costId])
  @@index([styleNumber, season])
  @@index([editedAt])
}

// Import history to track what files have been imported
model ImportLog {
  id          String   @id @default(cuid())
  fileName    String
  fileType    String   // 'linelist', 'sales', 'pricing', 'costs'
  season      String?
  recordCount Int
  importedBy  String?
  importedAt  DateTime @default(now())
}

// Season metadata - defines season status and expected data
model Season {
  id            String   @id @default(cuid())
  code          String   @unique // e.g., "27SP", "26FA"
  name          String   // e.g., "Spring 2027"
  status        String   @default("planning") // planning, selling, complete
  hasSalesData  Boolean  @default(false)
  hasLineList   Boolean  @default(false)
  hasPricing    Boolean  @default(false)
  hasCosts      Boolean  @default(false)
  hasInventory  Boolean  @default(false)
  startDate     DateTime?
  endDate       DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
  @@index([status])
}

// FG Inventory Movement data — each row is a movement transaction
model Inventory {
  id                  String   @id @default(cuid())
  styleNumber         String
  styleDesc           String?
  color               String?
  colorDesc           String?
  colorType           String?
  styleCategory       String?
  styleCatDesc        String?
  warehouse           String?
  movementType        String?        // Type column — e.g., "Receipt", "Shipment", "Adjustment"
  movementDate        DateTime?      // Date of the movement
  user                String?        // User who performed the movement
  group               String?        // Group code
  groupDesc           String?
  reference           String?
  customerVendor      String?        // Customer/Vendor
  reasonCode          String?        // Rea
  reasonDesc          String?        // Rea Desc
  costPrice           Float    @default(0)  // Cost/Price
  wholesalePrice      Float    @default(0)
  msrp                Float    @default(0)
  sizePricing         String?
  division            String?
  divisionDesc        String?
  label               String?
  labelDesc           String?
  period              String?        // Accounting period
  qty                 Int      @default(0)  // Movement qty (+/-)
  balance             Int      @default(0)  // Running balance after movement
  extension           Float    @default(0)  // Dollar extension
  prodMgr             String?
  oldStyleNumber      String?
  pantoneCsiDesc      String?
  controlNumber       String?
  asnStatus           String?
  store               String?
  salesOrderNumber    String?
  segmentCode         String?
  segmentDesc         String?
  costCode            String?
  costDesc            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([styleNumber])
  @@index([color])
  @@index([warehouse])
  @@index([movementType])
  @@index([movementDate])
  @@index([period])
  @@index([customerVendor])
}


// Daily aggregate snapshots of the Invoice table — independent backup
// trail for spotting regressions and verifying historical totals. Each
// row captures the same data the Invoice Month tab renders. See
// /api/admin/snapshot-invoices for the writer + retention policy. Full
// row-level recovery still relies on Neon point-in-time recovery; these
// snapshots exist to detect that something went wrong.
model InvoiceSnapshot {
  id                String   @id @default(cuid())
  takenAt           DateTime @default(now())
  trigger           String   // "cron" or "manual"
  totalRows         Int
  totalNetInvoiced  Float
  yearMonth         Json     // [{ y, m, count, net }, ...]
  topStyles         Json     // top 500 by abs(net)
  topCustomers      Json     // top 500 by abs(net)

  @@index([takenAt])
}
