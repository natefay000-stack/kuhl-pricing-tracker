# Database URL for PostgreSQL (Neon)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/database?schema=public"

# Required to enable destructive admin endpoints (wipe-all-invoices,
# delete-invoices-by-year, delete-invoice-range, purge-legacy-seasons,
# restore-invoice-snapshot). Set to a long random string. Without it,
# all destructive POSTs return 503.
#
# Manual call:  POST /api/admin/wipe-all-invoices?token=$ADMIN_TOKEN&...
ADMIN_TOKEN="set-me-to-a-long-random-string"

# Used by Vercel Cron Jobs to authenticate themselves to the snapshot
# endpoint. Vercel sets the Authorization: Bearer <CRON_SECRET> header
# automatically on cron requests when this env var is configured.
CRON_SECRET="another-long-random-string"
